{
  "schemaVersion": 1,
  "id": "mcclothing",
  "version": "${version}",
  "name": "MC Clothing",
  "description": "Dyeable, pattern-customizable clothing layers (overalls, aprons, t-shirts, vests, pants, shorts) that drape over the player and provide warmth.",
  "authors": ["mc-clothing"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.mcclothing.MCClothing"],
    "client": ["com.mcclothing.MCClothingClient"]
  },
  "mixins": [
    "mcclothing.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*",
    "trinkets": ">=3.10.0"
  }
}
